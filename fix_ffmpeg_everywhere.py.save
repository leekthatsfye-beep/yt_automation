import shutil
import sys
from pathlib import Path


def get_ffmpeg_path() -> str:
    path = shutil.which("ffmpeg")
    if path:
        return path

    fallback = "/opt/homebrew/bin/ffmpeg"
    if Path(fallback).exists():
        return fallback

    sys.exit("❌ ffmpeg not found.")


